{
  "id": "codebuddy_cn",
  "platformId": "codebuddy_cn",
  "version": "1.0.0",
  "apiVersion": 1,
  "minCoreVersion": "1.0.0",
  "displayName": "CodeBuddy CN",
  "entry": "runtime/index.json",
  "packageMode": "hotUpdate",
  "installKind": "sidecarAdapter",
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-codebuddy-cn-adapter",
    "macosEntry": "adapter/macos/cockpit-codebuddy-cn-adapter",
    "windowsEntry": "adapter/windows/cockpit-codebuddy-cn-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-codebuddy-cn-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.importJson",
      "accounts.importLocal",
      "accounts.addToken",
      "accounts.export",
      "accounts.indexPath",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.syncToWorkbuddy",
      "accounts.updateTags",
      "quota.alertPayload",
      "oauth.start",
      "oauth.complete",
      "oauth.cancel",
      "oauth.restorePendingListener",
      "switch.inject",
      "switch.injectDefaultProfile",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "tokenImport",
    "localImport",
    "switch",
    "quota",
    "runtime",
    "instances",
    "sync"
  ],
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-07-01",
      "notes": [
        "Platform has been split into an independent package and now runs independently from the host application."
      ],
      "locales": {
        "zh-CN": {
          "notes": [
            "平台拆成独立的包独立运行。"
          ]
        },
        "zh-TW": {
          "notes": [
            "平台拆成獨立的包並獨立運行。"
          ]
        }
      }
    }
  ],
  "contributions": {
    "platforms": [
      {
        "id": "codebuddy_cn",
        "label": "CodeBuddy CN",
        "labelKey": "nav.codebuddyCn",
        "iconKey": "codebuddy_cn",
        "page": "codebuddy-cn"
      }
    ],
    "dataPaths": [
      "codebuddy_cn_accounts.json",
      "codebuddy_cn_accounts",
      "codebuddy_cn_instances.json"
    ],
    "localStorageKeys": [
      "agtools.codebuddycn.accounts.cache",
      "agtools.codebuddycn.current_account_id",
      "agtools.codebuddycn.flow_notice_collapsed",
      "agtools.codebuddycn.instances.cache"
    ],
    "nativeBoundaries": []
  }
}
