+import { resolveCodexApiServiceCompatibilityBaseUrls } from "./codexApiServiceCompatibility.ts";
+
+test("normalizes a versioned service URL for each compatibility client", () => {
+  assert.deepEqual(
+    resolveCodexApiServiceCompatibilityBaseUrls(
